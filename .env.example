# 火山方舟「豆包」对话 API（OpenAI 兼容）
# 在控制台创建 API Key：https://www.volcengine.com/docs/82379/1541594
DOUBAO_API_KEY=

# 必填：推理接入点 ID（以 ep- 开头），在方舟「在线推理」里创建接入点后复制，不要填模型名如 doubao-xxx
# 用于「生成回复」；可为纯文本模型
DOUBAO_MODEL_ID=

# 识图用：同样必须填 ep- 开头的接入点 ID，且对应模型须支持多模态/图片
# 不填则识图沿用上面的 DOUBAO_MODEL_ID（也必须支持图片）
# DOUBAO_VISION_MODEL_ID=

# 可选：其他区域 Base URL，默认北京
# DOUBAO_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
