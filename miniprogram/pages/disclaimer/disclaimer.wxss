.scroll {
  height: 100vh;
  box-sizing: border-box;
}

.doc {
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.h1 {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
  color: #1a1a1a;
}

.h2 {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  margin: 28rpx 0 16rpx;
  color: #333;
}

.p {
  display: block;
  font-size: 28rpx;
  line-height: 1.75;
  color: #444;
  margin-bottom: 16rpx;
}
