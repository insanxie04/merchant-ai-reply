.index-root {
  min-height: 100%;
}

/* 主色 #FFD100，与网页版一致；底部为固定免责声明留出空间 */
.page {
  padding: 24rpx;
  padding-bottom: calc(24rpx + 160rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + 160rpx + env(safe-area-inset-bottom));
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #1a1a1a;
}

/* 评价区：上下约各占一半 */
.review-split {
  display: flex;
  flex-direction: column;
  min-height: 720rpx;
  border: 2rpx solid #ebebeb;
  border-radius: 16rpx;
  overflow: hidden;
}

.upload-half,
.textarea-half {
  flex: 1;
  min-height: 280rpx;
  display: flex;
  flex-direction: column;
}

.textarea-wrap {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 280rpx;
}

.review-clear-btn {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 32rpx;
  height: 32rpx;
  line-height: 28rpx;
  text-align: center;
  font-size: 32rpx;
  color: #999999;
  z-index: 2;
}

.upload-half {
  background: #fafafa;
  border-bottom: 2rpx solid #ebebeb;
}

.upload-empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.upload-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.upload-main {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.upload-sub {
  font-size: 24rpx;
  color: #888;
  text-align: center;
}

.preview-img {
  flex: 1;
  width: 100%;
  min-height: 240rpx;
  max-height: 400rpx;
}

.preview-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 16rpx;
}

.preview-actions-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.preview-actions-row-top {
  justify-content: center;
}

.preview-actions-row-bottom {
  justify-content: flex-end;
}

.review-textarea {
  flex: 1;
  width: 100%;
  min-height: 280rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.ph-gray {
  color: #999999;
}

.error-text {
  display: block;
  color: #dc2626;
  font-size: 26rpx;
  margin-top: 12rpx;
}

/* 参数区 */
.param-block {
  margin-bottom: 24rpx;
}

.param-block-extra {
  margin-top: 8rpx;
  margin-bottom: 0;
}

.custom-input-fullwidth {
  width: 100%;
  display: block;
}

.param-row-dual {
  display: flex;
  gap: 20rpx;
}

.param-half {
  flex: 1;
  min-width: 0;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  min-height: 88rpx;
  padding: 0 20rpx;
  background: #fff;
  border: 2rpx solid #e5e5e5;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.picker-text {
  font-size: 28rpx;
  flex: 1;
  min-width: 0;
}

.picker-text.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-arrow {
  font-size: 22rpx;
  color: #888;
  margin-left: 12rpx;
}

.custom-input {
  margin-top: 16rpx;
  height: 88rpx;
  min-height: 88rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 按钮 */
.btn-row {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.btn-primary,
.btn-secondary,
.btn-outline,
.btn-ghost,
.btn-sm,
.action-pill {
  font-size: 28rpx;
}

.btn-primary {
  background: #ffd100 !important;
  color: #1a1a1a !important;
  font-weight: 600;
  border-radius: 16rpx !important;
  height: 96rpx !important;
  min-height: 88rpx;
  line-height: 96rpx;
  border: none !important;
}

/* 可点/加载中：保持高亮黄，避免微信 button[disabled] 默认半透明发灰 */
.btn-primary:not(.btn-primary-idle)[disabled] {
  opacity: 1 !important;
}

/* 无内容可生成时：整体灰态，无黄边 */
.btn-primary.btn-primary-idle {
  background: #f3f3f3 !important;
  color: #888888 !important;
  border: none !important;
  box-shadow: none;
}

.btn-primary::after,
.btn-secondary::after,
.btn-outline::after,
.btn-ghost::after {
  border: none;
}

.btn-secondary {
  background: #f3f3f3 !important;
  color: #1a1a1a !important;
  font-weight: 600;
  border-radius: 16rpx !important;
  height: 96rpx !important;
  min-height: 88rpx;
  line-height: 96rpx;
  border: 2rpx solid #ffd100 !important;
}

/* 有截图或已输入评价时：识别并可点，主色美团黄 #FFD700 */
.btn-secondary-on {
  background: #ffd700 !important;
  color: #1a1a1a !important;
  border: 2rpx solid #ffd700 !important;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.btn-outline {
  background: #fff !important;
  color: #1a1a1a !important;
  border: 2rpx solid #ffd100 !important;
  border-radius: 12rpx !important;
  padding: 12rpx 24rpx !important;
  min-height: 72rpx;
  line-height: 1.4;
}

.btn-ghost {
  background: transparent !important;
  color: #666 !important;
  border: none !important;
  font-size: 26rpx !important;
}

.btn-sm {
  min-height: 72rpx !important;
}

.status-block {
  text-align: center;
  padding: 32rpx;
}

.status-text {
  color: #666;
  font-size: 28rpx;
}

.error-banner {
  background: #fef2f2;
  color: #b91c1c;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #666;
  margin-bottom: 16rpx;
  text-align: center;
}

.reply-list {
  margin-bottom: 24rpx;
}

.reply-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.reply-body {
  font-size: 28rpx;
  line-height: 1.65;
  color: #1a1a1a;
  display: block;
  margin-bottom: 20rpx;
}

.reply-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  align-items: center;
}

.action-pill {
  min-height: 72rpx !important;
  min-width: 120rpx;
  padding: 0 20rpx !important;
  line-height: 72rpx;
  background: #f5f5f5 !important;
  color: #333 !important;
  border-radius: 12rpx !important;
  font-size: 24rpx !important;
  border: 2rpx solid #e8e8e8 !important;
}

.action-pill.active {
  background: #ffd100 !important;
  border-color: #e6bc00 !important;
  color: #1a1a1a !important;
}

.action-pill.active-d {
  background: #e8e8e8 !important;
  border-color: #ccc !important;
}

.action-pill.active-f {
  background: #ffd100 !important;
  border-color: #e6bc00 !important;
  color: #1a1a1a !important;
  font-weight: 600;
}

.action-pill.primary-lite {
  border-color: #ffd100 !important;
}

/* 收藏夹 */
.fav-panel {
  margin-bottom: 24rpx;
}

.fav-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 88rpx;
}

.fav-title {
  font-size: 30rpx;
  font-weight: 600;
}

.fav-chevron {
  font-size: 24rpx;
  color: #888;
  transition: transform 0.2s;
}

.fav-chevron.open {
  transform: rotate(180deg);
}

.fav-body {
  padding-top: 16rpx;
  border-top: 2rpx solid #f0f0f0;
  margin-top: 8rpx;
}

.fav-tip {
  font-size: 22rpx;
  color: #888;
  line-height: 1.5;
  display: block;
  margin-bottom: 20rpx;
}

.fav-tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.fav-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  font-size: 26rpx;
  color: #666;
}

.fav-tab.on {
  background: rgba(255, 209, 0, 0.25);
  color: #1a1a1a;
  font-weight: 600;
  border: 2rpx solid #ffd100;
}

.fav-empty {
  text-align: center;
  color: #999;
  padding: 40rpx;
  font-size: 26rpx;
}

.fav-item {
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.fav-text {
  font-size: 26rpx;
  line-height: 1.55;
  display: block;
  margin-bottom: 12rpx;
}

.fav-note {
  width: 100%;
  min-height: 80rpx;
  font-size: 24rpx;
  padding: 12rpx;
  border: 2rpx solid #eee;
  border-radius: 8rpx;
  box-sizing: border-box;
  margin-bottom: 12rpx;
}

.fav-item-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.btn-danger-text {
  background: transparent !important;
  color: #b91c1c !important;
  border: none !important;
}

/* 底部合规链接 */
.legal-bar {
  display: flex;
  justify-content: center;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  padding: 32rpx 16rpx 16rpx;
  font-size: 22rpx;
  color: #999;
}

.legal-link {
  color: #888;
  text-decoration: underline;
}

.legal-sep {
  color: #ccc;
}

/* 统一 Toast：半透明黑底、白字、8px 圆角、垂直居中 */
.custom-toast-wrap {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  z-index: 10000;
}

.custom-toast-box {
  background: rgba(51, 51, 51, 0.92);
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 16rpx;
  padding: 24rpx 40rpx;
  max-width: 80%;
  text-align: center;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.12);
}

/* 固定底部免责声明（不随页面滚动） */
.ai-disclaimer-fixed {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(40px + constant(safe-area-inset-bottom));
  bottom: calc(40px + env(safe-area-inset-bottom));
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
  z-index: 500;
  pointer-events: none;
}
