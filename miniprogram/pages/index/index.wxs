/** 按当前回复行 id 判断是否已收藏（避免同文多条卡片状态错乱） */
function favoritedRow(list, rowId) {
  if (!list || !rowId) return false;
  for (var i = 0; i < list.length; i++) {
    if (list[i].replyRowId === rowId) return true;
  }
  return false;
}

/** 读取点赞/点踩状态（兼容数字下标与字符串 key） */
function feedback(map, idx) {
  if (!map) return "";
  var s = "" + idx;
  if (map[s]) return map[s];
  if (map[idx]) return map[idx];
  return "";
}

module.exports.favoritedRow = favoritedRow;
module.exports.feedback = feedback;
